<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE task PUBLIC "-//OASIS//DTD DITA Task//EN" "task.dtd">
<task id="store_halloween_decorations">
    <title>How to Store Halloween Decorations After Use</title>

    <shortdesc> This task explains how to store Halloween decorations after the holiday to keep them
        organized and in good condition for future use. </shortdesc>

    <taskbody>


        <prereq>
            <p id="p_e2r_yq1_n3c">Before you begin, make sure you have:</p>
            <ul id="ul_f2r_yq1_n3c">
                <li>Storage containers or boxes</li>
                <li>Trash or recycling bags</li>
                <li>Labels or a marker</li>
            </ul>
        </prereq>

        <context>
            <p id="p_g2r_yq1_n3c">Proper storage of Halloween decorations helps prevent damage, reduces clutter, and
                makes decorations easier to find next year. </p>
        </context>

        <steps id="steps_h2r_yq1_n3c">

            <step>
                <cmd>Remove decorations from their display locations.</cmd>
            </step>

            <step>
                <cmd>Clean decorations if necessary.</cmd>
                <info>
                    <p id="p_i2r_yq1_n3c">Remove dirt, dust, or residue before storage.</p>
                </info>
                <stepxmp>
                    <p id="p_j2r_yq1_n3c">Wipe plastic decorations with a dry cloth and allow any damp items to dry
                        completely.</p>
                </stepxmp>
            </step>

            <step>
                <cmd>Sort decorations by type or location.</cmd>
                <info>
                    <p id="p_k2r_yq1_n3c">Grouping similar items makes future setup easier.</p>
                </info>
            </step>

            <step>
                <cmd>Place decorations into labeled containers.</cmd>
            </step>

            <step>
                <cmd>Store containers in a dry, secure location.</cmd>
            </step>
        </steps>

        <result>
            <p id="p_l2r_yq1_n3c">Halloween decorations are safely stored and ready for reuse.</p>
        </result>

        <postreq>
            <p id="p_m2r_yq1_n3c">Dispose of damaged or unwanted decorations responsibly.</p>
        </postreq>

    </taskbody>
</task>
