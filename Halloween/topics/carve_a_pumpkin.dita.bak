<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE task PUBLIC "-//OASIS//DTD DITA Task//EN" "task.dtd">
<task id="carve_pumpkin">
    <title>Carve a Pumpkin</title>

    <shortdesc> This task explains how to carve a pumpkin for Halloween decoration. </shortdesc>

    <taskbody>
        <prereq id="prereq_ymh_rzt_m3c">
            <p id="p_x2r_yq1_n3c">You will need the following items:</p>
            <ul id="ul_zmh_rzt_m3c">
                <li>A pumpkin</li>
                <li>A carving knife or pumpkin carving tool</li>
                <li>A spoon or scoop</li>
                <li>A marker</li>
                <li>A candle or LED light</li>
            </ul>
        </prereq>
        <context id="context_anh_rzt_m3c">
            <p id="p_y2r_yq1_n3c">Pumpkin carving is a traditional Halloween activity that involves cutting a design
                into a pumpkin and placing a light inside it.</p>
        </context>



        <steps id="steps_bnh_rzt_m3c">
            <step>
                <cmd>Cut an opening in the top of the pumpkin.</cmd>
                <info>
                    <p id="p_z2r_yq1_n3c">Angle the knife slightly inward to prevent the lid from falling in.</p>
                </info>
            </step>
            <step>
                <cmd>Scoop out the seeds and pulp.</cmd>
            </step>
            <step>
                <cmd>Draw a design on the pumpkin.</cmd>
                <info>
                    <p id="p_afr_yq1_n3c">You can draw a face or any simple shape.</p>
                </info>
            </step>
            <step>
                <note type="caution" id="note_cnh_rzt_m3c">
                    <p id="p_bfr_yq1_n3c">Cut away from your hands to avoid injury.</p>
                </note>
                <cmd>Cut along the drawn lines.</cmd>
            </step>
            <step>
                <cmd>Place a light inside the pumpkin and replace the lid.</cmd>
            </step>
        </steps>

        <result id="result_dnh_rzt_m3c">
            <p id="p_cfr_yq1_n3c">The pumpkin is carved and ready to be displayed.</p>
        </result>

        <postreq id="postreq_enh_rzt_m3c">
            <p id="p_dfr_yq1_n3c">Dispose of pumpkin scraps and clean the tools after use.</p>
        </postreq>

    </taskbody>
    <related-links>
        <link href="pumpkins.dita"/>
    </related-links>
</task>
